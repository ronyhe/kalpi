{
    "$schema": "./node_modules/oxfmt/configuration_schema.json",
    "useTabs": false,
    "tabWidth": 4,
    "endOfLine": "lf",
    "printWidth": 120,
    "singleQuote": true,
    "quoteProps": "as-needed",
    "trailingComma": "none",
    "semi": false,
    "arrowParens": "avoid",
    "bracketSpacing": true,
    "experimentalSortImports": {}
}
